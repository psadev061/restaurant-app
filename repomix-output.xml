                            </span>
                            <span className="text-xs font-semibold text-price-green ml-auto">
                              = {formatBs(item.itemTotalBsCents)}
                            </span>
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                  {!hasModifiers && (
                    <span className="text-sm font-semibold text-price-green whitespace-nowrap">
                      {formatBs(item.itemTotalBsCents)}
                    </span>
                  )}
                </div>
