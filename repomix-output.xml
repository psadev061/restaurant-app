  useEffect(() => {
    let active = true;
    let timeoutId: NodeJS.Timeout;
    let attempt = 0;
    const BASE_INTERVAL = 5000;
    const MAX_INTERVAL = 30000;

    const poll = async () => {
      if (!active) return;

      try {
        const res = await fetch(`/api/orders/${orderId}/status`);
